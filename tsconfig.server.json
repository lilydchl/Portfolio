{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist/server",
    "rootDir": "./src/server",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/server/**/*.ts"]
}
